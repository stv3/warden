# ── Warden — example environment file ─────────────────────────────────────────
# Copy to .env and fill in real values. NEVER commit .env to git.
#
# Generate WARDEN_SECRET_KEY with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"

# ── HTTPS / Let's Encrypt ──────────────────────────────────────────────────────
# Required when using docker-compose.https.yml for TLS termination.
# Run ./init-letsencrypt.sh after setting these.
WARDEN_DOMAIN=warden.yourdomain.com
CERTBOT_EMAIL=you@yourdomain.com

# ── Ports ─────────────────────────────────────────────────────────────────────
# Host port that the UI is reachable on. Change if 80 or 443 is already in use.
# If you change these, restart containers — CORS origins are auto-computed from them.
# Tip: if 80 is taken, use 8080. Access Warden at http://localhost:8080
WARDEN_HTTP_PORT=80
WARDEN_HTTPS_PORT=443

# ── Application ────────────────────────────────────────────────────────────────
# Set to "production" to enforce security checks at startup (blocks insecure defaults).
# Leave as "development" for local installs; change to "production" for real deployments.
WARDEN_ENV=development

WARDEN_SECRET_KEY=change-me-generate-with-secrets-token-hex-32
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me-use-a-strong-password
AUTH_TOKEN_EXPIRE_MINUTES=480
AUTH_MAX_ATTEMPTS=10

# CORS: comma-separated list of allowed origins (no wildcards).
# Default covers local HTTP and HTTPS (self-signed). For production set to your domain:
#   CORS_ORIGINS=https://warden.yourdomain.com
CORS_ORIGINS=http://localhost,https://localhost

# API docs: disabled by default in production for security
# Set to "true" only in dev/staging environments
WARDEN_DOCS_ENABLED=false

# ── Database ───────────────────────────────────────────────────────────────────
POSTGRES_DB=vuln_orchestrator
POSTGRES_USER=vuln
POSTGRES_PASSWORD=change-me-strong-random-password
DATABASE_URL=postgresql://vuln:change-me-strong-random-password@db:5432/vuln_orchestrator

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── NVD (National Vulnerability Database) ─────────────────────────────────────
# Optional API key — free at https://nvd.nist.gov/developers/request-an-api-key
# Without a key: 5 requests/30s. With a key: 50 requests/30s.
NVD_API_KEY=

# ── GreyNoise CVE Intelligence ─────────────────────────────────────────────────
# Optional — enriches findings with internet-wide CVE scanning/exploitation data.
# Free community tier: https://www.greynoise.io/plans
GREYNOISE_API_KEY=

# ── Nessus (self-hosted) ───────────────────────────────────────────────────────
NESSUS_URL=https://localhost:8834
NESSUS_USERNAME=
NESSUS_PASSWORD=
NESSUS_VERIFY_SSL=true

# ── Tenable.io (cloud) ─────────────────────────────────────────────────────────
TENABLE_ACCESS_KEY=
TENABLE_SECRET_KEY=

# ── Qualys VMDR ────────────────────────────────────────────────────────────────
QUALYS_API_URL=https://qualysapi.qualys.com
QUALYS_USERNAME=
QUALYS_PASSWORD=

# ── Jira ───────────────────────────────────────────────────────────────────────
JIRA_URL=
JIRA_USERNAME=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=

# ── Slack ──────────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
SLACK_KEV_CHANNEL=#vuln-kev-alerts

# ── Microsoft Defender for Endpoint ────────────────────────────────────────────
DEFENDER_TENANT_ID=
DEFENDER_CLIENT_ID=
DEFENDER_CLIENT_SECRET=
DEFENDER_MACHINE_GROUPS=

# ── CrowdStrike Falcon Spotlight ───────────────────────────────────────────────
CROWDSTRIKE_CLIENT_ID=
CROWDSTRIKE_CLIENT_SECRET=
CROWDSTRIKE_BASE_URL=

# ── Rapid7 InsightVM ───────────────────────────────────────────────────────────
RAPID7_URL=
RAPID7_API_KEY=
RAPID7_SITE_ID=
