<?xml version='1.0' encoding='utf-8' ?>

<!-- Warden Executive Dashboard - Tableau Workbook Template
     Generated for use with Warden Vulnerability Orchestrator
     Data source: /api/export/tableau/findings.csv

     Setup:
     1. Open this file in Tableau Desktop (2020.1+)
     2. Update the data source connection to point to your Warden CSV export
        OR use the Web Data Connector with your /api/export/tableau/findings.csv endpoint
     3. Refresh data and publish to Tableau Server/Cloud
-->
<workbook source-build='2023.1.0' source-platform='mac' version='21.2' xmlns:user='http://www.tableausoftware.com/xml/user'>
  <preferences>
    <color-palette name='Warden Severity' type='ordered-sequential'>
      <color>#D73027</color>
      <color>#FC8D59</color>
      <color>#FEE090</color>
      <color>#91BFDB</color>
    </color-palette>
  </preferences>
  <datasources>
    <datasource caption='Warden Findings' inline='true' name='warden_findings' version='21.2'>
      <connection class='textscan' filename='warden-findings.csv' interpreter='' locale='en_US' separator=',' server='' >
        <relation name='warden-findings.csv' table='[warden-findings#csv]' type='table' />
        <metadata-records>
          <metadata-record class='column'>
            <remote-name>id</remote-name>
            <remote-type>7</remote-type>
            <local-name>[id]</local-name>
            <parent-name>[warden-findings#csv]</parent-name>
            <remote-alias>id</remote-alias>
            <ordinal>0</ordinal>
            <local-type>string</local-type>
            <aggregation>Count</aggregation>
          </metadata-record>
          <metadata-record class='column'>
            <remote-name>cve_id</remote-name>
            <remote-type>7</remote-type>
            <local-name>[cve_id]</local-name>
            <parent-name>[warden-findings#csv]</parent-name>
            <remote-alias>cve_id</remote-alias>
            <ordinal>1</ordinal>
