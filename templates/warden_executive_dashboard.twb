  <dashboards>

    <!-- Dashboard 1: Executive Overview -->
    <dashboard name='Executive Overview'>
      <style />
      <size maxheight='2000' maxwidth='1800' minheight='600' minwidth='800' />
      <zones>
        <zone h='12000' id='1' type='layout-flow' w='48000' x='0' y='0'>
          <zone-style>
            <format attr='border-color' field='0' value='#000000' />
            <format attr='border-style' field='0' value='none' />
            <format attr='border-width' field='0' value='0' />
            <format attr='background-color' field='0' value='#1f2937' />
          </zone-style>
          <!-- Title Banner -->
          <zone h='1500' id='2' type='text' w='48000' x='0' y='0'>
            <zone-style>
              <format attr='background-color' field='0' value='#111827' />
            </zone-style>
            <formatted-text>
              <run bold='true' fontsize='18' fontcolor='#FFFFFF'>Warden Vulnerability Management — Executive Overview</run>
            </formatted-text>
          </zone>
          <!-- Row 1: Severity Distribution + KEV Risk Matrix -->
          <zone h='5000' id='3' type='layout-flow-horiz' w='48000' x='0' y='1500'>
            <zone h='5000' id='4' name='Severity Distribution' type='worksheet' w='24000' x='0' y='1500' />
            <zone h='5000' id='5' name='KEV Risk Matrix' type='worksheet' w='24000' x='24000' y='1500' />
          </zone>
          <!-- Row 2: Environment Exposure + SLA Heatmap -->
          <zone h='5500' id='6' type='layout-flow-horiz' w='48000' x='0' y='6500'>
            <zone h='5500' id='7' name='Environment Exposure' type='worksheet' w='24000' x='0' y='6500' />
            <zone h='5500' id='8' name='SLA Compliance Heatmap' type='worksheet' w='24000' x='24000' y='6500' />
          </zone>
        </zone>
      </zones>
      <devicelayouts>
        <devicelayout auto='true' name='Phone'>
          <size maxheight='2000' maxwidth='1000' minheight='400' minwidth='320' sizing-mode='vscroll' />
        </devicelayout>
      </devicelayouts>
    </dashboard>

    <!-- Dashboard 2: Asset & Operations -->
    <dashboard name='Asset and Operations'>
      <style />
      <size maxheight='2000' maxwidth='1800' minheight='600' minwidth='800' />
      <zones>
        <zone h='12000' id='10' type='layout-flow' w='48000' x='0' y='0'>
          <!-- Title Banner -->
          <zone h='1500' id='11' type='text' w='48000' x='0' y='0'>
            <zone-style>
              <format attr='background-color' field='0' value='#111827' />
            </zone-style>
            <formatted-text>
              <run bold='true' fontsize='18' fontcolor='#FFFFFF'>Warden Vulnerability Management — Asset &amp; Operations</run>
            </formatted-text>
          </zone>
          <!-- Row 1: Top Assets + Findings by Type -->
          <zone h='5000' id='12' type='layout-flow-horiz' w='48000' x='0' y='1500'>
            <zone h='5000' id='13' name='Top Assets at Risk' type='worksheet' w='24000' x='0' y='1500' />
            <zone h='5000' id='14' name='Findings by Type' type='worksheet' w='24000' x='24000' y='1500' />
          </zone>
          <!-- Row 2: Risk Trend + Owner Accountability -->
          <zone h='5500' id='15' type='layout-flow-horiz' w='48000' x='0' y='6500'>
            <zone h='5500' id='16' name='Risk Trend Over Time' type='worksheet' w='24000' x='0' y='6500' />
            <zone h='5500' id='17' name='Owner Accountability' type='worksheet' w='24000' x='24000' y='6500' />
          </zone>
        </zone>
      </zones>
    </dashboard>

  </dashboards>

  <!-- Global Filters available on dashboards -->
  <windows>
    <window class='dashboard' maximized='true' name='Executive Overview'>
      <simple-id uuid='{00000001-0000-0000-0000-000000000001}' />
    </window>
    <window class='dashboard' name='Asset and Operations'>
      <simple-id uuid='{00000001-0000-0000-0000-000000000002}' />
    </window>
  </windows>

</workbook>
