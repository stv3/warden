            <remote-type>5</remote-type>
            <local-name>[epss_score]</local-name>
            <parent-name>[warden-findings#csv]</parent-name>
            <remote-alias>epss_score</remote-alias>
            <ordinal>6</ordinal>
            <local-type>real</local-type>
            <aggregation>Average</aggregation>
          </metadata-record>
          <metadata-record class='column'>
            <remote-name>in_kev</remote-name>
            <remote-type>7</remote-type>
            <local-name>[in_kev]</local-name>
            <parent-name>[warden-findings#csv]</parent-name>
            <remote-alias>in_kev</remote-alias>
            <ordinal>7</ordinal>
            <local-type>boolean</local-type>
            <aggregation>Count</aggregation>
          </metadata-record>
          <metadata-record class='column'>
            <remote-name>kev_due_date</remote-name>
            <remote-type>7</remote-type>
            <local-name>[kev_due_date]</local-name>
            <parent-name>[warden-findings#csv]</parent-name>
            <remote-alias>kev_due_date</remote-alias>
            <ordinal>8</ordinal>
            <local-type>date</local-type>
            <aggregation>Year</aggregation>
          </metadata-record>
          <metadata-record class='column'>
            <remote-name>asset_name</remote-name>
            <remote-type>7</remote-type>
            <local-name>[asset_name]</local-name>
            <parent-name>[warden-findings#csv]</parent-name>
            <remote-alias>asset_name</remote-alias>
            <ordinal>9</ordinal>
            <local-type>string</local-type>
            <aggregation>Count</aggregation>
          </metadata-record>
          <metadata-record class='column'>
            <remote-name>asset_ip</remote-name>
            <remote-type>7</remote-type>
            <local-name>[asset_ip]</local-name>
            <parent-name>[warden-findings#csv]</parent-name>
            <remote-alias>asset_ip</remote-alias>
            <ordinal>10</ordinal>
            <local-type>string</local-type>
            <aggregation>Count</aggregation>
          </metadata-record>
          <metadata-record class='column'>
            <remote-name>asset_environment</remote-name>
            <remote-type>7</remote-type>
            <local-name>[asset_environment]</local-name>
            <parent-name>[warden-findings#csv]</parent-name>
            <remote-alias>asset_environment</remote-alias>
            <ordinal>11</ordinal>
            <local-type>string</local-type>
            <aggregation>Count</aggregation>
          </metadata-record>
          <metadata-record class='column'>
            <remote-name>asset_criticality</remote-name>
            <remote-type>5</remote-type>
            <local-name>[asset_criticality]</local-name>
            <parent-name>[warden-findings#csv]</parent-name>
            <remote-alias>asset_criticality</remote-alias>
            <ordinal>12</ordinal>
            <local-type>real</local-type>
            <aggregation>Average</aggregation>
          </metadata-record>
          <metadata-record class='column'>
            <remote-name>sources</remote-name>
            <remote-type>7</remote-type>
            <local-name>[sources]</local-name>
            <parent-name>[warden-findings#csv]</parent-name>
            <remote-alias>sources</remote-alias>
            <ordinal>13</ordinal>
            <local-type>string</local-type>
            <aggregation>Count</aggregation>
          </metadata-record>
          <metadata-record class='column'>
            <remote-name>finding_type</remote-name>
            <remote-type>7</remote-type>
            <local-name>[finding_type]</local-name>
            <parent-name>[warden-findings#csv]</parent-name>
            <remote-alias>finding_type</remote-alias>
            <ordinal>14</ordinal>
            <local-type>string</local-type>
            <aggregation>Count</aggregation>
          </metadata-record>
          <metadata-record class='column'>
            <remote-name>status</remote-name>
            <remote-type>7</remote-type>
            <local-name>[status]</local-name>
            <parent-name>[warden-findings#csv]</parent-name>
            <remote-alias>status</remote-alias>
            <ordinal>15</ordinal>
            <local-type>string</local-type>
            <aggregation>Count</aggregation>
          </metadata-record>
          <metadata-record class='column'>
            <remote-name>owner</remote-name>
            <remote-type>7</remote-type>
            <local-name>[owner]</local-name>
            <parent-name>[warden-findings#csv]</parent-name>
            <remote-alias>owner</remote-alias>
            <ordinal>16</ordinal>
            <local-type>string</local-type>
            <aggregation>Count</aggregation>
          </metadata-record>
          <metadata-record class='column'>
            <remote-name>sla_due_date</remote-name>
            <remote-type>7</remote-type>
            <local-name>[sla_due_date]</local-name>
            <parent-name>[warden-findings#csv]</parent-name>
            <remote-alias>sla_due_date</remote-alias>
            <ordinal>17</ordinal>
            <local-type>date</local-type>
            <aggregation>Year</aggregation>
          </metadata-record>
          <metadata-record class='column'>
            <remote-name>first_seen</remote-name>
            <remote-type>7</remote-type>
            <local-name>[first_seen]</local-name>
            <parent-name>[warden-findings#csv]</parent-name>
            <remote-alias>first_seen</remote-alias>
            <ordinal>18</ordinal>
            <local-type>datetime</local-type>
            <aggregation>Year</aggregation>
          </metadata-record>
          <metadata-record class='column'>
            <remote-name>last_seen</remote-name>
            <remote-type>7</remote-type>
            <local-name>[last_seen]</local-name>
            <parent-name>[warden-findings#csv]</parent-name>
            <remote-alias>last_seen</remote-alias>
            <ordinal>19</ordinal>
            <local-type>datetime</local-type>
            <aggregation>Year</aggregation>
          </metadata-record>
          <metadata-record class='column'>
            <remote-name>resolved_at</remote-name>
            <remote-type>7</remote-type>
            <local-name>[resolved_at]</local-name>
            <parent-name>[warden-findings#csv]</parent-name>
            <remote-alias>resolved_at</remote-alias>
            <ordinal>20</ordinal>
            <local-type>datetime</local-type>
            <aggregation>Year</aggregation>
          </metadata-record>
          <metadata-record class='column'>
            <remote-name>remediation_action</remote-name>
            <remote-type>7</remote-type>
            <local-name>[remediation_action]</local-name>
            <parent-name>[warden-findings#csv]</parent-name>
            <remote-alias>remediation_action</remote-alias>
            <ordinal>21</ordinal>
            <local-type>string</local-type>
            <aggregation>Count</aggregation>
          </metadata-record>
        </metadata-records>
      </connection>

      <!-- Calculated Fields -->

      <!-- Risk Band: categorical grouping of risk_score -->
      <column caption='Risk Band' datatype='string' default-role='dimension' default-type='nominal' name='[Risk Band]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [risk_score] >= 80 THEN "Critical Risk"
ELSEIF [risk_score] >= 60 THEN "High Risk"
ELSEIF [risk_score] >= 40 THEN "Medium Risk"
ELSEIF [risk_score] >= 20 THEN "Low Risk"
ELSE "Informational"
END' />
      </column>

      <!-- KEV Urgency: prioritization combining KEV flag and SLA overdue status -->
      <column caption='KEV Urgency' datatype='string' default-role='dimension' default-type='nominal' name='[KEV Urgency]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [in_kev] = TRUE AND NOT ISNULL([kev_due_date]) AND [kev_due_date] &lt; TODAY() THEN "OVERDUE - KEV"
ELSEIF [in_kev] = TRUE AND NOT ISNULL([kev_due_date]) AND DATEDIFF(&apos;day&apos;, TODAY(), [kev_due_date]) &lt;= 7 THEN "Due This Week - KEV"
ELSEIF [in_kev] = TRUE AND NOT ISNULL([kev_due_date]) AND DATEDIFF(&apos;day&apos;, TODAY(), [kev_due_date]) &lt;= 30 THEN "Due This Month - KEV"
ELSEIF [in_kev] = TRUE THEN "KEV - No Due Date"
ELSE "Not in KEV"
END' />
      </column>

      <!-- Days Open: age of the finding -->
      <column caption='Days Open' datatype='integer' default-role='measure' default-type='quantitative' name='[Days Open]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF NOT ISNULL([resolved_at]) THEN DATEDIFF(&apos;day&apos;, DATE([first_seen]), DATE([resolved_at]))
ELSE DATEDIFF(&apos;day&apos;, DATE([first_seen]), TODAY())
END' />
      </column>

      <!-- Age Category: bucket findings by age -->
      <column caption='Age Category' datatype='string' default-role='dimension' default-type='nominal' name='[Age Category]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Days Open] &lt;= 7 THEN "0-7 days"
ELSEIF [Days Open] &lt;= 30 THEN "8-30 days"
ELSEIF [Days Open] &lt;= 90 THEN "31-90 days"
ELSEIF [Days Open] &lt;= 180 THEN "91-180 days"
ELSE "180+ days"
END' />
      </column>

      <!-- SLA Status: derived from sla_due_date -->
      <column caption='SLA Status' datatype='string' default-role='dimension' default-type='nominal' name='[SLA Status]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF ISNULL([sla_due_date]) THEN "No SLA"
ELSEIF [sla_due_date] &lt; TODAY() AND [status] != "resolved" THEN "Overdue"
ELSEIF DATEDIFF(&apos;day&apos;, TODAY(), [sla_due_date]) &lt;= 7 THEN "Due This Week"
ELSE "On Track"
END' />
      </column>

      <!-- Is Active: open or in_progress -->
      <column caption='Is Active' datatype='boolean' default-role='dimension' default-type='nominal' name='[Is Active]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[status] = &quot;open&quot; OR [status] = &quot;in_progress&quot;' />
      </column>

      <!-- Severity Order: for sorting -->
      <column caption='Severity Order' datatype='integer' default-role='measure' default-type='quantitative' name='[Severity Order]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [severity]
WHEN "critical" THEN 1
WHEN "high" THEN 2
WHEN "medium" THEN 3
WHEN "low" THEN 4
ELSE 5
END' />
      </column>

    </datasource>
  </datasources>

  <worksheets>

    <!-- Sheet 1: Severity Distribution (Pie Chart) -->
    <worksheet name='Severity Distribution'>
      <table>
        <view>
          <datasources>
            <datasource caption='Warden Findings' name='warden_findings' />
          </datasources>
          <aggregation value='true'/>
        </view>
        <rows />
        <cols />
        <shelf-sorts>
          <shelf-sort-v2 dimension-measure='measure' direction='ASC' is-active='true' measure='[warden_findings].[Severity Order]' output-field-ordinal='0' shelf='color' />
        </shelf-sorts>
        <panes>
          <pane>
            <mark class='Pie' />
            <encodings>
              <color>
                <field caption='Severity' datatype='string' name='[warden_findings].[severity]' role='dimension' type='nominal' />
                <palette name='Warden Severity' />
              </color>
              <angle>
                <field caption='Number of Records' datatype='integer' name='[warden_findings].[Number of Records]' role='measure' type='quantitative' />
              </angle>
              <label>
                <field caption='Severity' datatype='string' name='[warden_findings].[severity]' role='dimension' type='nominal' />
              </label>
              <size>
                <field caption='Number of Records' datatype='integer' name='[warden_findings].[Number of Records]' role='measure' type='quantitative' />
              </size>
            </encodings>
          </pane>
        </panes>
        <filters>
          <filter class='categorical' column='[warden_findings].[Is Active]'>
            <groupfilter function='member' level='[warden_findings].[Is Active]' member='true' />
          </filter>
        </filters>
      </table>
    </worksheet>

    <!-- Sheet 2: KEV Risk Matrix (Bar Chart - KEV Urgency by Severity) -->
    <worksheet name='KEV Risk Matrix'>
      <table>
