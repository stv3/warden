            <groupfilter function='member' level='[warden_findings].[Is Active]' member='true' />
          </filter>
        </filters>
        <sorts>
          <sort column='[warden_findings].[risk_score]' direction='DESC' using='field' />
        </sorts>
      </table>
    </worksheet>

